          },
          "albumName": {
            "type": "string",
            "example": "Summer Vacation"
          },
          "createdAt": {
            "type": "string",
            "example": "2026-03-28T00:00:00Z"
          }
        },
        "required": [
          "id",
          "albumName",
          "createdAt"
        ]
      }
    }
